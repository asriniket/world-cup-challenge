# Live match data, goals, cards, and results
# Provider: API-Football / API-SPORTS
# Free tier: 100 requests/day. The app caches this route for 30 minutes.
API_FOOTBALL_KEY=
API_FOOTBALL_FIXTURE_CACHE_MINUTES=30
API_FOOTBALL_FIXTURE_DAILY_LIMIT=55

# Server-only private draw seed. Do not expose this as VITE_*.
# Rotate this if pre-draw assignments leak.
DRAW_SEED_SECRET=

# Optional durable red-card cache. This lets the server fetch card events only
# when a fixture is live or first final, then remember finished fixtures forever.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Keeps API-Football event calls inside the free tier alongside the 30-minute fixtures poll.
RED_CARD_EVENT_DAILY_LIMIT=35
RED_CARD_EVENT_CHECK_MINUTES=30

# Optional manual overrides for card-level stats if a provider has a bad event.
# Example:
# LIVE_STAT_OVERRIDES_JSON=[{"teamId":"paraguay","redCards":1,"redCardMinute":68,"yellowCards":4}]
LIVE_STAT_OVERRIDES_JSON=

# Futures odds provider. Free-compatible choices:
#   the-odds-api
#   generic
ODDS_PROVIDER=the-odds-api

# The Odds API outrights/futures
# Free tier: 500 credits/month. The app caches this route for 6 hours.
THE_ODDS_API_KEY=
THE_ODDS_SPORT_KEY=soccer_fifa_world_cup_winner
THE_ODDS_REGIONS=us
# Optional, overrides regions when set. Example: draftkings,fanduel
THE_ODDS_BOOKMAKERS=
# Durable server-side odds cache/rate guard. Defaults to 6-hour refreshes and
# keeps headroom under the 500-credit/month free tier.
ODDS_CACHE_HOURS=6
ODDS_API_MONTHLY_LIMIT=450

# Generic custom odds endpoint returning:
# { "odds": [{ "teamId": "france", "probability": 0.15, "source": "...", "updatedAt": "..." }] }
ODDS_API_URL=
ODDS_API_TOKEN=
