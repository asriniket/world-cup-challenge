# Live match data, goals, fixtures, and results
# Provider: WorldCup26 API (free, no API key, 104-match feed)
WORLDCUP26_API_URL=https://worldcup26.ir/get/games
WORLDCUP26_CACHE_MINUTES=6
WORLDCUP26_DAILY_LIMIT=240

# Futures odds provider: The Odds API
# Free tier: 500 credits/month. This app requests one market (outrights)
# and one region by default, then caches successful snapshots for 6 hours.
THE_ODDS_API_KEY=
THE_ODDS_SPORT_KEY=soccer_fifa_world_cup_winner
THE_ODDS_REGIONS=us
# Optional, overrides THE_ODDS_REGIONS when set. Up to 10 bookmakers costs
# the same 1 credit as one region for the single outrights market.
# Example: draftkings,fanduel
THE_ODDS_BOOKMAKERS=
THE_ODDS_CACHE_HOURS=6
THE_ODDS_MONTHLY_LIMIT=450

# Durable server-side cache and budget guard. Recommended for production.
# Upstash Redis has a free tier large enough for this app's small snapshots.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Server-only private draw seed. Do not expose this as VITE_*.
# Rotate this if pre-draw assignments leak.
DRAW_SEED_SECRET=

# Optional manual overrides for provider data correction only.
# Example:
# LIVE_STAT_OVERRIDES_JSON=[{"teamId":"united-states","played":1,"goalsFor":4,"goalsAgainst":1,"cleanSheets":0,"form":"W"}]
LIVE_STAT_OVERRIDES_JSON=
